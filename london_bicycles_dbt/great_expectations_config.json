{
  "datasource": {
    "name": "london_bicycles_bigquery",
    "connection_string": "bigquery://pydrive-colab-2",
    "type": "bigquery"
  },
  "validation_suites": [
    {
      "suite_name": "stg_trips_expectations",
      "description": "Data quality validations for staging trips",
      "dataset": "london_bicycles_staging",
      "table": "stg_trips",
      "expectations": [
        {
          "expectation_type": "expect_column_values_to_be_unique",
          "column": "trip_id",
          "description": "Trip IDs must be unique"
        },
        {
          "expectation_type": "expect_column_values_to_be_between",
          "column": "duration",
          "min_value": 0,
          "max_value": 86400,
          "description": "Trip duration must be between 0 and 86400 seconds (24 hours)"
        },
        {
          "expectation_type": "expect_column_values_to_be_greater_than_or_equal",
          "column": "duration_minutes",
          "min_value": 0,
          "description": "Duration in minutes must be non-negative"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "trip_id",
          "description": "Trip ID cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "start_station_id",
          "description": "Start station ID cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "end_station_id",
          "description": "End station ID cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "trip_date",
          "description": "Trip date cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "duration_minutes",
          "description": "Duration in minutes cannot be null"
        }
      ]
    },
    {
      "suite_name": "stg_stations_expectations",
      "description": "Data quality validations for staging stations",
      "dataset": "london_bicycles_staging",
      "table": "stg_stations",
      "expectations": [
        {
          "expectation_type": "expect_column_values_to_be_unique",
          "column": "station_id",
          "description": "Station IDs must be unique"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "station_id",
          "description": "Station ID cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "station_name",
          "description": "Station name cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "latitude",
          "description": "Latitude cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "longitude",
          "description": "Longitude cannot be null"
        },
        {
          "expectation_type": "expect_column_values_to_be_between",
          "column": "latitude",
          "min_value": 51.3,
          "max_value": 51.7,
          "description": "Latitude must be within London bounds (51.3-51.7)"
        },
        {
          "expectation_type": "expect_column_values_to_be_between",
          "column": "longitude",
          "min_value": -0.3,
          "max_value": 0.1,
          "description": "Longitude must be within London bounds (-0.3 to 0.1)"
        }
      ]
    },
    {
      "suite_name": "fct_trips_expectations",
      "description": "Data quality validations for fact trips",
      "dataset": "london_bicycles_marts",
      "table": "fct_trips",
      "expectations": [
        {
          "expectation_type": "expect_column_values_to_be_unique",
          "column": "trip_id",
          "description": "Trip IDs must be unique in fact table"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "trip_id",
          "description": "Trip ID cannot be null in fact table"
        },
        {
          "expectation_type": "expect_column_values_to_be_greater_than_or_equal",
          "column": "duration_minutes",
          "min_value": 0,
          "description": "Duration in minutes must be non-negative"
        },
        {
          "expectation_type": "expect_column_values_to_be_in_set",
          "column": "trip_duration_category",
          "value_set": ["short", "medium", "long", "very_long"],
          "description": "Trip duration category must be one of: short, medium, long, very_long"
        }
      ]
    },
    {
      "suite_name": "dim_stations_expectations",
      "description": "Data quality validations for dimension stations",
      "dataset": "london_bicycles_marts",
      "table": "dim_stations",
      "expectations": [
        {
          "expectation_type": "expect_column_values_to_be_unique",
          "column": "station_id",
          "description": "Station IDs must be unique in dimension"
        },
        {
          "expectation_type": "expect_column_values_to_not_be_null",
          "column": "station_id",
          "description": "Station ID cannot be null in dimension"
        },
        {
          "expectation_type": "expect_column_values_to_be_in_set",
          "column": "station_area",
          "value_set": ["Central", "Outer"],
          "description": "Station area must be either Central or Outer"
        }
      ]
    }
  ],
  "data_quality_thresholds": {
    "critical": 0.95,
    "warning": 0.90,
    "info": 0.80
  },
  "validation_schedule": {
    "frequency": "daily",
    "time": "02:00",
    "timezone": "UTC"
  }
}
